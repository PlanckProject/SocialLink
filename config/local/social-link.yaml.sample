application:
  mode: single

admin:
  username: admin
  email: admin@example.com
  password: ${ADMIN_PASSWORD}
  display_name: Your Name

uploads:
  max_mb: 8

themes:
  seed_file: /app/theme.json
  max_preset_per_user: 5
  max_custom_per_user: 5

# Content limits applied to a profile's links and groups.
content:
  # Maximum number of link groups a profile may create.
  max_groups: 5
