# syntax=docker/dockerfile:1

# ---------- Build stage ----------
FROM docker.io/library/rust:1.97-alpine AS builder
RUN apk add --no-cache build-base
WORKDIR /build

# Copy manifests first, then sources. Cargo.lock is optional (it is git-ignored
# and may not be committed).
COPY api/Cargo.toml api/Cargo.lock* ./
COPY api/src ./src
COPY api/theme.json ./theme.json

# Compile with BuildKit cache mounts. Unlike plain layer caching, these mounts
# persist the Cargo registry and the target/ directory ACROSS builds — even when
# a layer is invalidated by a Cargo.toml or source change — so dependencies are
# compiled once and reused instead of rebuilt from scratch every time (the ~15
# min hit only happens on the very first build or a cleared cache). mongodb uses
# rustls by default, so no OpenSSL is needed. The binary is copied out of the
# cached target/ because cache-mount contents are not part of the image layer.
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/build/target,sharing=locked \
    cargo build --release \
    && cp target/release/api /build/api

# ---------- Runtime stage ----------
FROM docker.io/library/alpine:3
RUN apk add --no-cache tini ca-certificates
WORKDIR /app
COPY --from=builder /build/api /usr/local/bin/api
COPY --from=builder /build/theme.json ./theme.json
COPY config ./config

ENV SOCIAL_LINK_ENV=local
EXPOSE 3001
VOLUME ["/data/uploads", "/data/logs"]
ENTRYPOINT ["/sbin/tini", "--"]
CMD ["api"]
